<!DOCTYPE html>
<html>
<head>
  <title>Ọlámidé & Olúwaseunfúnmi</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    body{
      font-family: Arial, sans-serif;
      background: linear-gradient(-45deg, #fff5f7, #ffe4ec, #fff);
      background-size: 400% 400%;
      animation: bg 15s ease infinite;
      text-align:center;
      padding:50px 20px;
      color:#4a1d2f;
      overflow:hidden;
    }

    @keyframes bg {
      0% {background-position:0% 50%;}
      50% {background-position:100% 50%;}
      100% {background-position:0% 50%;}
    }

    .heart {
      position:absolute;
      color:pink;
      animation: floatUp 10s linear infinite;
      opacity:0.6;
    }

    @keyframes floatUp {
      0% {transform:translateY(100vh); opacity:0;}
      20% {opacity:0.7;}
      100% {transform:translateY(-10vh); opacity:0;}
    }

    .card{
      background:white;
      max-width:500px;
      margin:auto;
      padding:30px;
      border-radius:20px;
      box-shadow:0 5px 20px rgba(0,0,0,.1);
      position:relative;
      z-index:2;
    }

    h1{
      font-size:2.5rem;
      margin-bottom:10px;
    }

    .sub{
      font-style: italic;
      margin-bottom: 15px;
    }

    .time {
      font-size: 1.5rem;
      margin-top: 10px;
      font-weight: bold;
    }

    .music-btn{
      margin-top:20px;
      padding:12px 20px;
      border:none;
      border-radius:30px;
      background:#b91c5c;
      color:white;
      font-size:16px;
    }
  </style>
</head>

<body>

  <!-- hearts -->
  <div class="heart" style="left:10%">❤️</div>
  <div class="heart" style="left:30%; animation-delay:2s">💖</div>
  <div class="heart" style="left:60%; animation-delay:4s">❤️</div>
  <div class="heart" style="left:80%; animation-delay:6s">💞</div>

  <div class="card">
    <p>Together with their families</p>

    <h1>Ọlámidé & Olúwaseunfúnmi</h1>

    <p class="sub">
      Ọlámidé introduces Olúwaseunfúnmi
    </p>

    <p>
      Request the honour of your presence
      at their introduction celebration
    </p>

    <h2>June 27, 2026</h2>

    <div class="time">12:00 PM</div>

    <p>
      Shórèmékún Street<br>
      Abuja, Nigeria
    </p>

    <button class="music-btn" onclick="startMusic()">
      ▶️ Play Music
    </button>

    <audio id="bgMusic" loop>
      <source src="music.mp3" type="audio/mp3">
    </audio>
  </div>

<script>
let musicStarted = false;
const music = document.getElementById("bgMusic");
const btn = document.querySelector(".music-btn");

function startMusic(){
  if(musicStarted) return;

  music.volume = 0;
  music.play();

  let vol = 0;
  const fade = setInterval(() => {
    if(vol < 1){
      vol += 0.05;
      music.volume = vol;
    } else {
      clearInterval(fade);
    }
  }, 150);

  btn.innerText = "🎶 Playing...";
  musicStarted = true;
}

document.body.addEventListener("click", () => {
  if(!musicStarted){
    startMusic();
  }
});
</script>

</body>
</html>
